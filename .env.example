# =============================================================================
# DataStrat AI - Universal Configuration Template
# =============================================================================
# This file defines the baseline configuration for development and production.
# For production, run `./deploy.sh` to generate a customized `.env` file.
COMPOSE_PROFILES=local-storage

# =============================================================================
# 1. Routing & Identity (Zitadel)
# =============================================================================
# These determine how users access the app and how OIDC redirects are handled.

# Public-facing domains (Accessed by browser)
APP_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost:8000
ZITADEL_PUBLIC_URL=http://localhost:8080

# Internal Routing (Used by Nginx and inter-container communication)
AUTH_DOMAIN=localhost
AUTH_PORT=8080
AUTH_HOST=localhost:8080
AUTH_SECURE=false

# OIDC Flow
OIDC_CALLBACK_URL=http://localhost/api/v1/auth/oidc/callback

# Zitadel System
ZITADEL_MASTERKEY=V+xQoNkjZPoDKnkKuKemcvZyViDcEj60
ZITADEL_DB_PASSWORD=zitadel_secure_password
ZITADEL_ADMIN_PASSWORD=Admin123!
ZITADEL_INTERNAL_URL=http://zitadel:8080

# =============================================================================
# 2. Infrastructure Services (Host-Agnostic)
# =============================================================================
# Each service can be a local container or a managed cloud resource.

# --- PostgreSQL (Main DB) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=datastrat
DB_PASS=datastrat
DB_NAME=datastrat
DATABASE_URL=

# --- Redis (Cache & Queue) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=

# --- Qdrant (Vector DB) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=

# --- MinIO / S3 (Object Storage) ---
STORAGE_HOST=minio
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=datastrat-evidence
STORAGE_ENDPOINT_URL=

# =============================================================================
# 3. LLM (Large Language Model) Configuration
# =============================================================================
# Supported providers: openai, azure, anthropic, ollama, openrouter
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4
LLM_BASE_URL=

# =============================================================================
# 4. Security & Performance
# =============================================================================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
APP_VERSION=latest
ENVIRONMENT=development
